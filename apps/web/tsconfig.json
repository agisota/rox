{
	"extends": "@rox/typescript/next.json",
	"compilerOptions": {
		"paths": {
			"@/*": ["./src/*"]
		},
		"lib": ["ES2022", "DOM", "DOM.Iterable", "WebWorker"],
		"types": ["@serwist/next/typings"]
	},
	"include": ["**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
	"exclude": ["node_modules", "**/*.test.ts", "**/*.test.tsx"]
}
