{
	"extends": "expo/tsconfig.base",
	"compilerOptions": {
		"strict": true,
		"skipLibCheck": true,
		"paths": {
			"@/*": ["./*"],
			"@rox/tab-bar": ["./modules/tab-bar/src/index.tsx"]
