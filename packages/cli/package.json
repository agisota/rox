{
	"name": "@rox/cli",
	"version": "0.2.22",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "dotenv -e ../../.env -o -- sh -c 'exec env ROX_API_URL=$NEXT_PUBLIC_API_URL cli-framework dev \"$@\"' --",
		"build": "cli-framework build",
		"build:darwin-arm64": "cli-framework build --target=bun-darwin-arm64 --outfile=./dist/rox-darwin-arm64",
		"build:linux-x64": "cli-framework build --target=bun-linux-x64 --outfile=./dist/rox-linux-x64",
		"build:all": "bun run build:darwin-arm64 && bun run build:linux-x64",
		"build:dist": "bun run scripts/build-dist.ts",
		"typecheck": "tsc --noEmit",
		"test": "bun test"
	},
	"dependencies": {
		"@clack/prompts": "0.10.1",
		"@rox/cli-framework": "workspace:*",
		"@rox/host-service": "workspace:*",
		"@rox/shared": "workspace:*",
		"@rox/trpc": "workspace:*",
		"@trpc/client": "11.16.0",
		"date-fns": "4.1.0",
		"ink": "7.0.1",
		"mime-types": "3.0.2",
		"react": "19.2.3",
		"superjson": "2.2.6"
	},
	"devDependencies": {
		"@rox/typescript": "workspace:*",
		"@types/mime-types": "3.0.1",
		"@types/react": "19.2.14",
		"bun-types": "1.3.11",
		"typescript": "6.0.3"
	}
}
