			"types": "./src/index.ts",
			"default": "./src/index.ts"
		},
		"./object-store": {
			"types": "./src/object-store.ts",
			"default": "./src/object-store.ts"
		},
		"./vector-store": {
			"types": "./src/vector-store.ts",
			"default": "./src/vector-store.ts"
		},
		"./ai-provider": {
			"types": "./src/ai-provider.ts",
			"default": "./src/ai-provider.ts"
		},
		"./embed-text": {
			"types": "./src/embed-text.ts",
