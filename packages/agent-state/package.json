{
	"name": "@rox/agent-state",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"default": "./src/index.ts"
		},
		"./core": {
			"types": "./src/core/index.ts",
			"default": "./src/core/index.ts"
		},
		"./client": {
			"types": "./src/client/index.ts",
			"default": "./src/client/index.ts"
		},
		"./host": {
			"types": "./src/host/index.ts",
			"default": "./src/host/index.ts"
		},
		"./schema": {
			"types": "./src/schema.ts",
			"default": "./src/schema.ts"
		}
