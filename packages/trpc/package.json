{
	"name": "@rox/trpc",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"default": "./src/index.ts"
		},
		"./integrations/*": {
			"types": "./src/lib/integrations/*/index.ts",
			"default": "./src/lib/integrations/*/index.ts"
		},
		"./automation-dispatch": {
			"types": "./src/router/automation/dispatch.ts",
			"default": "./src/router/automation/dispatch.ts"
		},
		"./profile-stats": {
			"types": "./src/router/profile/stats.ts",
			"default": "./src/router/profile/stats.ts"
		},
		"./crypto": {
			"types": "./src/lib/crypto.ts",
			"default": "./src/lib/crypto.ts"
		},
		"./agent-source-schema": {
			"types": "./src/router/agent-source/schema.ts",
			"default": "./src/router/agent-source/schema.ts"
		},
		"./integration-secret": {
			"types": "./src/lib/integrations/secret-store.ts",
			"default": "./src/lib/integrations/secret-store.ts"
		},
		"./drive-economy": {
			"types": "./src/router/drive/quota.ts",
			"default": "./src/router/drive/quota.ts"
		},
		"./mail-transport": {
			"types": "./src/router/mail/transport.ts",
			"default": "./src/router/mail/transport.ts"
		},
		"./calendar-reminders": {
			"types": "./src/router/calendar/reminders.ts",
			"default": "./src/router/calendar/reminders.ts"
		},
		"./calendar-feed": {
			"types": "./src/router/calendar/feed.ts",
			"default": "./src/router/calendar/feed.ts"
		}
	},
	"scripts": {
		"clean": "git clean -xdf .cache .turbo dist node_modules",
		"test": "bun test --isolate",
		"typecheck": "tsc --noEmit --emitDeclarationOnly false"
	},
	"dependencies": {
		"@linear/sdk": "68.1.1",
		"@rox/analytics": "workspace:*",
		"@rox/auth": "workspace:*",
		"@rox/collab": "workspace:*",
		"@rox/comms-core": "workspace:*",
		"@rox/db": "workspace:*",
		"@rox/host-provisioner": "workspace:*",
		"@rox/rtc": "workspace:*",
		"@rox/runtime-clients": "workspace:*",
		"@rox/shared": "workspace:*",
		"@rox/storage": "workspace:*",
		"@rox/workflow-core": "workspace:*",
		"@rox/workflow-runtime": "workspace:*",
		"@t3-oss/env-core": "0.13.11",
		"@trpc/server": "11.16.0",
		"@upstash/qstash": "2.10.1",
		"@upstash/ratelimit": "2.0.8",
		"@upstash/redis": "1.37.0",
		"@vercel/blob": "2.3.2",
		"@vercel/kv": "3.0.0",
		"drizzle-orm": "0.45.2",
		"posthog-node": "5.38.0",
		"resend": "4.8.0",
		"superjson": "2.2.6",
		"zod": "4.3.6"
	},
	"devDependencies": {
		"@rox/typescript": "workspace:*",
		"@types/node": "24.12.0",
		"typescript": "6.0.3"
	}
}
